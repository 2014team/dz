<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.artcweb.dao.NailSecretDao">

	<resultMap type="com.artcweb.baen.NailSecret" id="result">
		<result property="id" column="id" />
		<result property="secretKey" column="secret_key" />
		<result property="orderId" column="order_id" />
		<result property="status" column="status" />
		<result property="createDate" column="create_date" />
		<result property="updateDate" column="update_date" />
	</resultMap>

	
	<insert id="saveBatch" parameterType="List">
      INSERT INTO t_nail_secret(secret_key,order_id,status,create_date,update_date)
      VALUES
	      <foreach collection="list" item="item" separator=",">
	      (#{item},null,0,now(),now())
	      </foreach>
     </insert>

	<!--删除 -->
	<delete id="delete" parameterType="Integer">
		delete from
		`t_nail_secret`
		where id=#{id}
	</delete>
	

	<!-- 批量删除 -->
	<delete id="deleteByBatch" parameterType="String">
		delete from
		`t_nail_secret`
		where
		FIND_IN_SET (id,#{id})
	</delete>
	
	<!-- 更新 -->
	<update id="update" parameterType="com.artcweb.baen.NailSecret">
		update `t_nail_secret`
		set
		order_id=#{orderId}
		,status=#{status}
		,update_date=now()
		where
		id=#{id}
	</update>


	<!-- 查找 -->
	<select id="get" parameterType="Integer" resultMap="result">
		select * from
		`t_nail_secret`
		where id = #{id}
		order by id limit 1
	</select>
	
	<select id="getByMap" parameterType="Map" resultMap="result">
		select * from
		`t_nail_secret`
		<where>
			<if test="null != secretKey and '' != secretKey">
				secret_key = #{secretKey}
			</if>
			<if test="null != status">
				and status = #{status}
			</if>
		</where>
		order by id limit 1
	</select>
	
	<select id="checkExit" parameterType="Map" resultType="int">
		select count(1) from
		`t_nail_secret`
		<where>
			<if test="null != secretKey and '' != secretKey">
				secret_key = #{secretKey}
			</if>
			<if test="null != status">
				and status = #{status}
			</if>
		</where>
	</select>

	
	<!-- 查询 -->
	<select id="searchByPage" parameterType="Map" resultType="com.artcweb.dto.NailSecretDto">
			SELECT t.`id` AS id,t.`secret_key` AS secretKey,t.`order_id` AS orderId,t.`status` AS STATUS,
			t.`create_date` AS createDate ,t.`update_date` AS updateDate,
			o.`mobile`,o.`username` AS username
			FROM `t_nail_secret` t LEFT JOIN `t_nail_order` o ON t.`order_id`=o.`id`
			<where>
				<if test="null != entity.secretKey and '' != entity.secretKey">
						t.secret_key = #{entity.secretKey}
				</if>
				<if test="null != entity.status">
						and t.status = #{entity.status}
				</if>
				<if test="null != entity.createDateStr and '' != entity.createDateStr">
						<![CDATA[  
						and t.create_date >= #{entity.beginDate} and  t.create_date <= #{entity.endDate} 
						]]>
				</if>
			</where>
			ORDER by id desc limit ${page.begin},${page.limit} 
	</select>
	
	<select id="searchByPageCount" parameterType="Map" resultType="int">
		SELECT count(1) FROM `t_nail_secret` t
		<where>
			<if test="null != entity.secretKey and '' != entity.secretKey">
					t.secret_key = #{entity.secretKey}
			</if>
			<if test="null != entity.status">
					and t.status = #{entity.status}
			</if>
			<if test="null != entity.createDateStr and '' != entity.createDateStr">
					<![CDATA[  
					and t.create_date >= #{entity.beginDate} and  t.create_date <= #{entity.endDate} 
					]]>
			</if>
		</where>
	</select>
	
	

</mapper> 